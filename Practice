async def guidewire_api_call_homeowners(blob_url: str) -> Dict[str, Any]:
    """
    Orchestrator function for HomeOwners (Residential Insurance) quote generation.
    
    Reads a residential insurance extraction JSON from Azure Blob and orchestrates
    the creation of a HomeOwners quote in Guidewire PolicyCenter through the following steps:
    
    1. Create Account (from extracted company/address data)
    2. Create Submission/Job (from extracted effective date and state)
    3. Configure HomeownersLine (prior insurance info - hardcoded)
    4. Add 4 Line-level Coverages (all hardcoded)
    5. Create Dwelling (property characteristics - hardcoded)
    6. Add 3 Dwelling-level Coverages (all hardcoded)
    7. Generate Quote
    8. Save output to Azure Blob
    
    Only 7 fields are extracted from the document:
    - Company Name, Organization Type
    - Address Line 1, City, State, Zip Code
    - Effective Date
    
    Everything else (dwelling details, coverages, prior insurance info) is hardcoded.
    
    Args:
        blob_url: Azure Blob URL pointing to extracted residential insurance JSON
        
    Returns:
        Dict with status, jobId, quote details, and output blob URL
        or error dict if any step fails
    """
    try:
        _require_env()
    except Exception as e:
        return {"status": False, "error": f"Environment misconfigured: {e}"}

    # Step 1: Read JSON from Blob
    try:
        document = await read_json_from_blob(blob_url)
        print("✓ Document read from blob")
    except Exception as e:
        return {"status": False, "error": f"Failed to read blob: {e}"}
    
    # Step 2: Map extracted data to model
    try:
        homeowners_data = map_document_to_homeowners_data(document)
        print("✓ Data mapped to QuoteDataHomeowners")
        print(f"  Company: {homeowners_data.company_name}")
        print(f"  State: {homeowners_data.state}")
        print(f"  Effective Date: {homeowners_data.job_effective_date}")
    except Exception as e:
        return {"status": False, "error": f"Failed to map data: {e}"}

    # Step 3: Create Account in Guidewire
    try:
        account_resp = post("/account/v1/accounts", build_account_payload(homeowners_data))
        account_id = account_resp["data"]["attributes"]["id"]
        print(f"✓ Account created: {account_id}")
    except Exception as e:
        return {"status": False, "error": f"Failed to create account: {e}"}

    # Step 4: Create Job (Submission) in Guidewire
    try:
        job_payload = build_job_payload(account_id, homeowners_data)
        # Override product ID for HomeOwners
        job_payload["data"]["attributes"]["product"]["id"] = "HomeownersProduct"
        
        job_resp = post("/job/v1/submissions", job_payload)
        job_id = job_resp["data"]["attributes"]["id"]
        print(f"✓ Job created: {job_id}")
    except Exception as e:
        return {"status": False, "error": f"Failed to create job: {e}"}

    # Step 5: Configure HomeownersLine (PATCH)
    try:
        patch(
            f"/job/v1/jobs/{job_id}/lines/HomeownersLine",
            build_homeowners_line_payload(homeowners_data)
        )
        print("✓ HomeownersLine configured")
    except Exception as e:
        return {"status": False, "error": f"Failed to configure HomeownersLine: {e}"}

    # Step 6: Add 4 Line-level Coverages
    try:
        for i, coverage in enumerate(get_line_level_coverages(), 1):
            post(
                f"/job/v1/jobs/{job_id}/lines/HomeownersLine/coverages",
                {"data": {"attributes": coverage}}
            )
        print(f"✓ Added 4 line-level coverages")
    except Exception as e:
        return {"status": False, "error": f"Failed to add line coverages: {e}"}

    # Step 7: Create Dwelling (Risk Object)
    try:
        dwelling_resp = post(
            f"/job/v1/jobs/{job_id}/lines/HomeownersLine/dwellings",
            build_dwelling_payload(homeowners_data)
        )
        dwelling_id = dwelling_resp["data"]["attributes"]["id"]
        print(f"✓ Dwelling created: {dwelling_id}")
    except Exception as e:
        return {"status": False, "error": f"Failed to create dwelling: {e}"}

    # Step 8: Add 3 Dwelling-level Coverages
    try:
        for i, coverage in enumerate(get_dwelling_level_coverages(), 1):
            post(
                f"/job/v1/jobs/{job_id}/lines/HomeownersLine/dwellings/{dwelling_id}/coverages",
                {"data": {"attributes": coverage}}
            )
        print(f"✓ Added 3 dwelling-level coverages")
    except Exception as e:
        return {"status": False, "error": f"Failed to add dwelling coverages: {e}"}

    # Step 9: Generate Quote
    try:
        quote_resp = post(f"/job/v1/jobs/{job_id}/quote", {})
        print("✓ Quote generated")
    except Exception as e:
        return {"status": False, "error": f"Failed to generate quote: {e}"}

    # Step 10: Parse blob URL and extract reference ID
    try:
        container, blob_path, ref_id, name = _ref_parse_blob_url(blob_url)
        print(f"✓ Blob URL parsed")
    except Exception as e:
        return {"status": False, "error": f"Failed to extract name from blob url: {e}"}

    # Step 11: Save quote response to blob
    try:
        output_blob_url = await save_json_output_to_blob(ref_id, name, quote_resp)
        print(f"✓ Quote saved to blob")
    except Exception as e:
        return {"status": False, "error": f"Failed to save output to blob: {e}"}

    # Return success response
    return {
        "status": True,
        "jobId": job_id,
        "quote": quote_resp,
        "output_blob_url": output_blob_url,
    }


