## new process retrieval with batched extraction (for testing/debugging)
async def process_retrieval_pg(reference_id: str, document_type: str) -> Dict[str, Any]:
    try:
        # ──────────────────────────────────────
        # 1. Load prompt + extraction rules
        # ──────────────────────────────────────
        db_data = prompt_manager.get_prompt_and_extraction_rules(document_type)
        if not db_data:
            raise RuntimeError(
                f"No prompt data found for document_type={document_type}"
            )

        raw_prompt = db_data["prompt"]
        extraction_rules = db_data.get("extraction_rules", {})
        if not extraction_rules:
            raise RuntimeError("No extraction rules found")

        # ──────────────────────────────────────
        # 2. Escape non-template braces
        #    (only allow the batching variable)
        # ──────────────────────────────────────
        prompt_template = escape_non_template_vars(
            raw_prompt,
            allowed_vars={"attributes_bundle"}
        )

        logger.info("🧠 Final Batched Prompt Loaded")

        batched_prompt = PromptTemplate(
            input_variables=["attributes_bundle"],
            template=prompt_template
        )

        # ──────────────────────────────────────
        # 3. Build LLM + VectorDB
        # ──────────────────────────────────────
        llm = AzureChatOpenAI(
            azure_endpoint=os.getenv("AZURE_OPENAI_ENDPOINT_PGVECTOR"),
            openai_api_key=os.getenv("AZURE_OPENAI_API_KEY_PGVECTOR"),
            openai_api_version=os.getenv("AZURE_OPENAI_API_VERSION_PGVECTOR"),
            deployment_name=os.getenv("AZURE_OPENAI_CHAT_DEPLOYMENT_PGVECTOR"),
            temperature=0,
        )

        vectordb = PostgresVectorStore(
            embeddings=embeddings,
            reference_id=reference_id
        )

        # ──────────────────────────────────────
        # 4. Concurrent PGVector retrieval
        # ──────────────────────────────────────
        async def fetch_context(attr: str, rule: Dict[str, Any]):
            k = int(rule.get("k", 13))
            instruction = rule.get("description", "")

            docs = await asyncio.to_thread(
                vectordb.similarity_search,
                attr,
                k
            )

            if not docs:
                return None

            return attr, {
                "instruction": instruction,
                "context": "\n".join(d.page_content for d in docs)
            }

        tasks = [
            fetch_context(attr, rule)
            for attr, rule in extraction_rules.items()
        ]

        results = await asyncio.gather(*tasks)

        attribute_contexts = {
            attr: payload
            for item in results
            if item is not None
            for attr, payload in [item]
        }

        if not attribute_contexts:
            return {
                "extracted": False,
                "reference_id": reference_id,
                "document_type": document_type,
                "error_message": "No relevant context found"
            }

        
        logger.info(
            "🧾 Attribute contexts ready: %d attribute(s) — %s",
            len(attribute_contexts),
            list(attribute_contexts.keys()),
        )


        # ──────────────────────────────────────
        # 5. SINGLE batched LLM call
        # ──────────────────────────────────────
        chain = batched_prompt | llm

        raw = await invoke_llm_with_retry(
            chain,
            {
                "attributes_bundle": json.dumps(
                    attribute_contexts,
                    ensure_ascii=False
                )
            }
        )

        text = raw.content if hasattr(raw, "content") else str(raw)
        json_text = _extract_json_object(text)
        parsed = json.loads(json_text)

        extracted = {
            k: v for k, v in parsed.items() if v is not None
        }

        if not extracted:
            return {
                "extracted": False,
                "reference_id": reference_id,
                "document_type": document_type,
                "error_message": "LLM returned no extracted attributes"
            }

        # ──────────────────────────────────────
        # 6. Group attributes (unchanged)
        # ──────────────────────────────────────
        grouped = await group_attributes_by_category_async(extracted)

        # ──────────────────────────────────────
        # 7. Save + upload
        # ──────────────────────────────────────
        output_dir = os.getenv("OUTPUT_DIR", "./data/extraction_outputs")
        os.makedirs(output_dir, exist_ok=True)

        timestamp = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
        filename = f"{reference_id}_{document_type}_{timestamp}.json"

        local_path = os.path.join(output_dir, filename)
        with open(local_path, "w", encoding="utf-8") as f:
            json.dump(grouped, f, indent=2, ensure_ascii=False)

        blob_url = upload_json_to_blob(
            container_name=os.getenv("OUTPUT_BLOB_CONTAINER", "extraction-results"),
            file_name=filename,
            data=grouped
        )

        # ──────────────────────────────────────
        # 8. Final response
        # ──────────────────────────────────────
        return {
            "extracted": True,
            "reference_id": reference_id,
            "document_type": document_type,
            "output_blob_url": blob_url
        }

    except Exception as e:
        logger.exception("❌ Extraction failed")
        return {
            "extracted": False,
            "reference_id": reference_id,
            "document_type": document_type,
            "error_message": str(e)
        }




