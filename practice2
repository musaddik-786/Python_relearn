# %%


async def stream():
        async for chunk in graph.astream({"messages": ["Start your task"]}, config={"recursion_limit": 50}, stream_mode="values"):
            if "agent" in chunk:
                messages = chunk["agent"]["messages"]
                for msg in messages:
                    if hasattr(msg, "content") and msg.content:
                        # Yield SSE formatted string
                        yield f"data: {msg.content}\n\n"
            if "tools" in chunk:
                messages = chunk["tools"]["messages"]
                for msg in messages:
                    if hasattr(msg, "content") and msg.content:
                        yield f"data: [Tool:{msg.name}] {msg.content}\n\n"

# %%
# Run the stream and print output
async def main():
    print("\n" + "="*60)
    print("🚀 Starting Graph Execution Stream")
    print("="*60 + "\n")
    async for event in stream():
        if event.startswith("data: "):
            print(event[6:].strip())

if __name__ == "__main__":
    asyncio.run(main())




