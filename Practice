class PostgreSQLPromptManager:
    """Manages dynamic prompt fetching from PostgreSQL (Prompt DB)"""

    def __init__(self):
        self.connection_params = {
            "host": os.getenv("PGHOST_PROMPT"),
            "port": int(os.getenv("PGPORT_PROMPT", "5432")),
            "database": os.getenv("PGDATABASE_PROMPT"),
            "user": os.getenv("PGUSER_PROMPT"),
            "password": os.getenv("PGPASSWORD_PROMPT"),
        }

        self.prompt_schema = os.getenv("PG_PROMPT_SCHEMA", "public")
        self.prompt_table  = os.getenv("PG_PROMPT_TABLE",  "ref_prompt_only")

        self.col_doc_type = os.getenv("PG_PROMPT_COL_DOCUMENT_TYPE", "document_type")
        self.col_prompt   = os.getenv("PG_PROMPT_COL_PROMPT", "prompt_text")
        self.col_rules    = os.getenv("PG_PROMPT_COL_EXTRACTION_RULES", "extraction_rules")

    def get_prompt_and_extraction_rules(self, document_type: str) -> Optional[Dict]:
        """
        Fetch prompt + extraction_rules for a document_type.

        Returns:
        {
          "prompt": <string>,
          "extraction_rules": { attribute_name: { ... } }
        }
        """
        try:
            conn = psycopg2.connect(**self.connection_params)
        except Exception as e:
            logger.error(f"❌ Prompt DB connection failed: {e}")
            return None

        try:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                query = f"""
                SELECT {self.col_prompt} AS prompt,
                       {self.col_rules}  AS extraction_rules
                FROM {self.prompt_schema}.{self.prompt_table}
                WHERE LOWER({self.col_doc_type}) = LOWER(%s)
                LIMIT 1
                """
                cur.execute(query, (document_type,))
                result = cur.fetchone()

                if not result or not result.get("prompt"):
                    logger.warning(f"⚠️ No prompt found for document_type={document_type}")
                    return None

                rules = {}
                raw_rules = result.get("extraction_rules")

                if raw_rules:
                    try:
                        if isinstance(raw_rules, str):
                            rules = json.loads(raw_rules)
                        elif isinstance(raw_rules, dict):
                            rules = raw_rules
                    except json.JSONDecodeError as e:
                        logger.warning(f"⚠️ Failed to parse extraction_rules JSON: {e}")
                        rules = {}

                logger.info(
                    f"✅ Loaded prompt + {len(rules)} extraction rules "
                    f"for document_type={document_type}"
                )

                return {
                    "prompt": result["prompt"],
                    "extraction_rules": rules
                }

        except Exception as e:
            logger.exception("❌ Error fetching prompt and extraction rules")
            return None

        finally:
            conn.close()


