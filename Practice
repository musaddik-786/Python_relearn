async def database_filler(result:dict):

#    print(f"[DEBUG] database_filler called")

#    print(f"[DEBUG] result type: {type(result)}")

#    print(f"[DEBUG] result value: {result}")

   if "Data_Filler" not in result:

       raise Exception("Data_Filler missing")

   data=result["Data_Filler"]

#    print(f"[DEBUG] Data_Filler value: {data}")

#    print(f"[DEBUG] Data_Filler type: {type(data)}")

   if not isinstance(data,list):

       raise Exception("Data_Filler must be list")

   processed=[]

   for index,item in enumerate(data):

    #    print(f"[DEBUG] Processing item {index}: {item}")

       if "Table_name" not in item:

           raise Exception(f"Row {index} missing Table_name")

       table=item["Table_name"]

       row=item.copy()

       row.pop("Table_name")

       processed.append({

           "table":table,

           "data":row,

           "row_number":index

       })

#    print(f"[DEBUG] processed rows: {processed}")

   return processed
def process_database(rows:list):

   engine=get_engine()

   inserted=0

   errors=[]

   with Session(engine) as session:

       for row in rows:

           try:

               table=row["table"]

               data=row["data"]

               row_number=row["row_number"]

               if table not in TABLE_MODEL_MAP:

                   raise Exception(f"Table mapping missing for {table}")

               model=TABLE_MODEL_MAP[table]

               filtered_data={

                   k:v for k,v in data.items()

                   if k in model.model_fields

               }

               for field in [

                   "approval_date_time",

                   "eligibility_check_date_time"

               ]:

                   if field in filtered_data:

                       if isinstance(filtered_data[field],str):

                           filtered_data[field]=datetime.fromisoformat(

                               filtered_data[field].replace(" ","T")

                           )

               db_row=model(**filtered_data)

               session.add(db_row)

            #    session.flush()        # ← flush immediately to get DB-generated id

            #    session.refresh(db_row) # ← refresh so id is populated

               inserted+=1

           except Exception as e:

               session.rollback()

               errors.append({

                   "row":row_number,

                   "error":str(e)

               })

       session.commit()

   return {

       "status":True,

       "rows_inserted":inserted,

       "rows_failed":len(errors),

       "errors":errors

   }
 


