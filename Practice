class PostgresVectorStore:
    def __init__(self, embeddings, reference_id: str):
        self.embeddings = embeddings
        self.reference_id = reference_id
        self.connection_params = {
            "host": os.getenv("PGHOST_PGVECTOR"),
            "port": int(os.getenv("PGPORT_PGVECTOR", "5432")),
            "database": os.getenv("PGDATABASE_PGVECTOR"),
            "user": os.getenv("PGUSER_PGVECTOR"),
            "password": os.getenv("PGPASSWORD_PGVECTOR"),
        }

        self.schema = os.getenv("PG_VECTOR_SCHEMA", "public")
        self.table = os.getenv("PG_VECTOR_TABLE", "pgvector_store")
        self.text_col = os.getenv("PG_COL_TEXT", "content")
        self.embedding_col = os.getenv("PG_COL_EMBEDDING", "embedding")
        self.ref_col = os.getenv("PG_COL_REFERENCE_ID", "mail_ref_id")
        self.meta_col = os.getenv("PG_COL_METADATA", "metadata")

    def similarity_search(self, query: str, k: int = 10) -> List[Document]:
        vec = self.embeddings.embed_query(query)
        vec_str = "[" + ",".join(f"{x:.8f}" for x in vec) + "]"

        sql_query = f"""
            SELECT {self.text_col}, {self.meta_col}
            FROM {self.schema}.{self.table}
            WHERE {self.ref_col} = %s
            ORDER BY {self.embedding_col} <=> %s::vector
            LIMIT %s
        """

        with psycopg2.connect(**self.connection_params) as conn:
            with conn.cursor() as cur:
                cur.execute(sql_query, (self.reference_id, vec_str, k))
                rows = cur.fetchall()

        return [
            Document(page_content=row[0], metadata=row[1] or {})
            for row in rows
        ]
