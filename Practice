import os
from phoenix.client import Client
from functools import lru_cache

PHOENIX_API_KEY = os.getenv("PHOENIX_API_KEY")
PHOENIX_ENDPOINT = os.getenv("PHOENIX_ENDPOINT")


@lru_cache
def load_prompt_template(prompt_version_id: str) -> str:
    client = Client(
        base_url=PHOENIX_ENDPOINT,
        api_key=PHOENIX_API_KEY
    )

    prompt = client.prompts.get(prompt_version_id=prompt_version_id)

    messages = prompt._template["messages"]

    system_prompt = next(
        (
            item["content"][0]["text"]
            for item in messages
            if item.get("role") == "system"
        ),
        None
    )

    if not system_prompt:
        raise ValueError("Prompt not found")

    return system_prompt


def get_langchain_prompt_template(prompt_version_id: str, allowed_vars: set[str]) -> str:

    raw_prompt = load_prompt_template(prompt_version_id)

    # Escape all braces
    escaped = raw_prompt.replace("{", "{{").replace("}", "}}")

    # Restore only allowed variables
    for var in allowed_vars:
        escaped = escaped.replace(
            "{{" + var + "}}",
            "{" + var + "}"
        )

    return escaped
