def _extract_json_object(text: str) -> str:
    cleaned = re.sub(r"```(?:json)?|```", "", text).strip()
    try:
        json.loads(cleaned)
        return cleaned
    except Exception:
        pass

    start = cleaned.find("{")
    if start == -1:
        raise ValueError("No JSON object found.")

    depth = 0
    for i in range(start, len(cleaned)):
        if cleaned[i] == "{":
            depth += 1
        elif cleaned[i] == "}":
            depth -= 1
            if depth == 0:
                candidate = cleaned[start:i + 1]
                json.loads(candidate)
                return candidate

    raise ValueError("Unbalanced JSON in response.")


def _validate_and_repair_grouping(
    input_attrs: Dict[str, str],
    grouped: Dict[str, Dict[str, Any]]
) -> Dict[str, Dict[str, Any]]:
    input_keys = set(input_attrs.keys())
    seen = set()
    repaired = {}

    for category, fields in grouped.items():
        if not isinstance(fields, dict):
            continue

        valid = {}
        for k, v in fields.items():
            if k in input_keys and k not in seen:
                valid[k] = v
                seen.add(k)

        if valid:
            repaired[category] = valid

    missing = input_keys - seen
    if missing:
        repaired.setdefault("Other", {})
        for k in missing:
            repaired["Other"][k] = input_attrs[k]

    return repaired

