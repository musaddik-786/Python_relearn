from datetime import datetime


async def database_filler(result: dict):

    def find_data_filler(obj):
        if isinstance(obj, dict):
            if "Data_Filler" in obj:
                return obj["Data_Filler"]
            for value in obj.values():
                found = find_data_filler(value)
                if found is not None:
                    return found

        elif isinstance(obj, list):
            for item in obj:
                found = find_data_filler(item)
                if found is not None:
                    return found

        return None

    data = find_data_filler(result)

    if data is None:
        raise Exception("Data_Filler missing")

    if not isinstance(data, list):
        raise Exception("Data_Filler must be list")

    processed = []

    for index, item in enumerate(data):
        if "Table_name" not in item:
            raise Exception(f"Row {index} missing Table_name")

        table = item["Table_name"]
        row = item.copy()
        row.pop("Table_name")

        processed.append({
            "table": table,
            "data": row,
            "row_number": index
        })

    return processed


def process_database(rows: list):
    engine = get_engine()
    inserted = 0
    errors = []

    with Session(engine) as session:
        for row in rows:
            try:
                table = row["table"]
                data = row["data"]
                row_number = row["row_number"]

                if table not in TABLE_MODEL_MAP:
                    raise Exception(f"Table mapping missing for {table}")

                model = TABLE_MODEL_MAP[table]

                filtered_data = {
                    k: v for k, v in data.items()
                    if k in model.model_fields
                }

                db_row = model(**filtered_data)
                session.add(db_row)
                session.commit()

                inserted += 1

            except Exception as e:
                session.rollback()
                errors.append({
                    "row": row_number,
                    "error": str(e)
                })

    return {
        "status": True,
        "rows_inserted": inserted,
        "rows_failed": len(errors),
        "errors": errors
    }


