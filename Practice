async def read_text_file_from_container(filename: str, container: str) -> str:
    """
    Reads the contents of a .txt file from the Azure Blob container Data_Raw_Text_Container_Name
    corresponding to the provided filename (without extension).
    Returns the text content of the file.
    """
    if not AZURE_STORAGE_CONNECTION_STRING:
        raise RuntimeError("AZURE_STORAGE_CONNECTION_STRING not set")

    # filename_without_ext = os.path.splitext(filename)[0]
    # blob_name = filename + ".txt"

    # filename_without_ext = os.path.splitext(filename)[0]
    # blob_name = filename_without_ext + ".txt"

    if filename.endswith(".txt"):
        blob_name = filename
    else:
        blob_name = filename + ".txt"

    # blob_name = filename

    async with BlobServiceClient.from_connection_string(AZURE_STORAGE_CONNECTION_STRING) as service:
        container_client = service.get_container_client(container)
        blob_client = container_client.get_blob_client(blob_name)
        try:
            await blob_client.get_blob_properties()
        except ResourceNotFoundError:
            raise FileNotFoundError(f"Blob not found in container '{Data_Raw_Text_Container_Name}': {blob_name}")

        downloader = await blob_client.download_blob()
        data = await downloader.readall()
        return data.decode("utf-8")

