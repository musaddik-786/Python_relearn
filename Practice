from sqlmodel import Session
from db import get_engine
from mapper import TABLE_MODEL_MAP
from datetime import datetime


async def database_filler(result:dict):

    # recursively find Data_Filler anywhere
    def find_data_filler(obj):

        if isinstance(obj, dict):

            for key,value in obj.items():

                normalized_key = key.lower().replace(" ","_")

                if normalized_key == "data_filler":

                    return value

                found = find_data_filler(value)

                if found is not None:

                    return found

        elif isinstance(obj, list):

            for item in obj:

                found = find_data_filler(item)

                if found is not None:

                    return found

        return None


    data = find_data_filler(result)

    if data is None:

        raise Exception("Data_Filler missing")

    if not isinstance(data,list):

        raise Exception("Data_Filler must be list")


    processed=[]

    for index,item in enumerate(data):

        if not isinstance(item,dict):

            raise Exception(f"Row {index} must be object")


        # find table key dynamically
        table_key=None

        for key in item.keys():

            normalized_key=key.lower().replace(" ","_")

            if normalized_key=="table_name":

                table_key=key
                break


        if not table_key:

            raise Exception(f"Row {index} missing Table_name")


        table=item[table_key].lower()


        row=item.copy()

        row.pop(table_key)


        # normalize column names
        normalized_row={}

        for k,v in row.items():

            normalized_row[k.lower()]=v


        processed.append({

            "table":table,

            "data":normalized_row,

            "row_number":index

        })


    return processed



def process_database(rows:list):

    engine=get_engine()

    inserted=0

    errors=[]


    with Session(engine) as session:

        for row in rows:

            try:

                table=row["table"]

                data=row["data"]

                row_number=row["row_number"]


                if table not in TABLE_MODEL_MAP:

                    raise Exception(f"Table mapping missing for {table}")


                model=TABLE_MODEL_MAP[table]


                filtered_data={

                    k:v for k,v in data.items()

                    if k in model.model_fields

                }


                # convert datetime fields automatically
                for field,value in filtered_data.items():

                    if isinstance(value,str):

                        try:

                            filtered_data[field]=datetime.fromisoformat(

                                value.replace(" ","T")

                            )

                        except:

                            pass


                db_row=model(**filtered_data)

                session.add(db_row)

                inserted+=1


            except Exception as e:

                session.rollback()

                errors.append({

                    "row":row_number,

                    "error":str(e)

                })


        session.commit()


    return {

        "status":True,

        "rows_inserted":inserted,

        "rows_failed":len(errors),

        "errors":errors

    }
