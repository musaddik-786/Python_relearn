from models import AgentEligibility
from sqlmodel import Session
from db import get_engine
from mapper import TABLE_MODEL_MAP
from datetime import datetime

async def database_filler(result:dict):
   if "Data_Filler" not in result:
       raise Exception("Data_Filler missing")
   data=result["Data_Filler"]
   if not isinstance(data,list):
       raise Exception("Data_Filler must be list")
   processed=[]
   for index,item in enumerate(data):
       if "Table_name" not in item:
           raise Exception(f"Row {index} missing Table_name")
       table=item["Table_name"]
       row=item.copy()
       row.pop("Table_name")
       processed.append({
           "table":table,
           "data":row,
           "row_number":index
       })
   return processed


def process_database(rows:list):
   engine=get_engine()
   inserted=0
   errors=[]
   with Session(engine) as session:
       for row in rows:
           try:
               table=row["table"]
               data=row["data"]
               row_number=row["row_number"]
               if table not in TABLE_MODEL_MAP:
                   raise Exception(
                       f"Table mapping missing for {table}"
                   )
               model=TABLE_MODEL_MAP[table]
               valid_columns=model.__fields__.keys()
               incoming_columns=data.keys()
               invalid_columns=set(incoming_columns)-set(valid_columns)
               if invalid_columns:
                   raise Exception(
                       f"Invalid columns {invalid_columns}"
                   )
               # datetime conversion
               datetime_fields=[
                   "approval_date_time",
                   "eligibility_check_date_time"
               ]
               for field in datetime_fields:
                   if field in data:
                       if isinstance(data[field],str):
                           data[field]=datetime.strptime(
                               data[field],
                               "%Y-%m-%d %H:%M:%S"
                           )
               db_row=model(**data)
               session.add(db_row)
               inserted+=1
           except Exception as e:
               errors.append({
                   "row":row_number,
                   "error":str(e)
               })
       session.commit()
   return {
       "status":True,
       "rows_inserted":inserted,
       "rows_failed":len(errors),
       "errors":errors
   }

